# StarTorque AI OS - Environment Variables Template
# Copy this file to .env and configure for your environment

# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0

# Security
API_KEY_REQUIRED=false
REQUEST_TIMEOUT=30000

# Agent Configuration
ENABLE_SENTIMENT_AGENT=true
ENABLE_EXTRACTION_AGENT=true
ENABLE_GENERATION_AGENT=true
ENABLE_CLASSIFICATION_AGENT=true

# Monitoring
ENABLE_METRICS=true
METRICS_INTERVAL=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
